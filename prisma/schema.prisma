generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  ACCOUNTANT
  TEACHER
  INVENTORY_MANAGER
}

enum BranchType {
  SCHOOL
  KINDERGARTEN
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

enum FeeType {
  TUITION
  TRANSPORT
  OTHER
}

enum FeeBucket {
  REGISTRATION
  INSTALLMENT_1
  INSTALLMENT_2
  INSTALLMENT_3
  INSTALLMENT_4
  BOOKS
  UNIFORM
  TRANSPORT
  OTHER
}

enum EmployeeCategory {
  TEACHING
  ADMINISTRATIVE
  SUPPORT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum TransportStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum InventoryCategoryType {
  TEXTBOOK
  UNIFORM
  CUSTOM
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(BRANCH_ADMIN)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributions InventoryDistribution[]
  classes       Class[]

  @@map("users")
}

model Branch {
  id        String     @id @default(cuid())
  name      String
  type      BranchType @default(SCHOOL)
  address   String?
  phone     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users       User[]
  classes     Class[]
  employees   Employee[]
  expenses    Expense[]
  inventoryItems InventoryItem[]
  inventoryCategories InventoryCategory[]
  students    Student[]

  @@map("branches")
}

model Class {
  id           String   @id @default(cuid())
  name         String
  grade        String?
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  teacherId    String?
  teacher      User?    @relation(fields: [teacherId], references: [id])
  academicYear String   @default("2024-2025")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students        Student[]
  feeTemplates    ClassFeeTemplate[]

  @@map("classes")
}

model ClassFeeTemplate {
  id           String  @id @default(cuid())
  classId      String
  class        Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear String
  registration Decimal @default(0) @db.Decimal(12, 2)
  installment1 Decimal @default(0) @db.Decimal(12, 2)
  installment2 Decimal @default(0) @db.Decimal(12, 2)
  installment3 Decimal @default(0) @db.Decimal(12, 2)
  installment4 Decimal @default(0) @db.Decimal(12, 2)
  books        Decimal @default(0) @db.Decimal(12, 2)
  uniform      Decimal @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fees Fee[]

  @@unique([classId, academicYear])
  @@map("class_fee_templates")
}

model Student {
  id             String        @id @default(cuid())
  fullName       String
  parentName     String?
  parentPhone    String?
  dateOfBirth    DateTime?
  gender         Gender?
  classId        String?
  class          Class?        @relation(fields: [classId], references: [id])
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id])
  enrollmentDate DateTime      @default(now())
  status         StudentStatus @default(ACTIVE)
  notes          String?
  isOrphan       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  fees                  Fee[]
  payments              Payment[]
  installments          Installment[]
  transportSubscription TransportSubscription?
  distributions         InventoryDistribution[]

  @@map("students")
}

model Fee {
  id           String     @id @default(cuid())
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type         FeeType    @default(TUITION)
  bucket       FeeBucket  @default(OTHER)
  amount       Decimal    @db.Decimal(12, 2)
  paidAmount   Decimal    @default(0) @db.Decimal(12, 2)
  description  String?
  academicYear String     @default("2024-2025")
  templateId   String?
  template     ClassFeeTemplate? @relation(fields: [templateId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  payments     Payment[]

  @@map("fees")
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeId         String?
  fee           Fee?          @relation(fields: [feeId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  receiptNumber String?       @unique
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  receipt Receipt?

  @@map("payments")
}

model Receipt {
  id           String   @id @default(cuid())
  paymentId    String   @unique
  payment      Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  imagePath    String
  originalName String
  uploadedAt   DateTime @default(now())

  @@map("receipts")
}

model Installment {
  id         String            @id @default(cuid())
  studentId  String
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Decimal           @db.Decimal(12, 2)
  dueDate    DateTime
  paidAmount Decimal           @default(0) @db.Decimal(12, 2)
  status     InstallmentStatus @default(PENDING)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("installments")
}

model TransportSubscription {
  id         String          @id @default(cuid())
  studentId  String          @unique
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  route      String?
  monthlyFee Decimal         @db.Decimal(12, 2)
  startDate  DateTime        @default(now())
  endDate    DateTime?
  status     TransportStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@map("transport_subscriptions")
}

model Employee {
  id          String           @id @default(cuid())
  fullName    String
  jobTitle    String?
  phone       String?
  email       String?
  branchId    String
  branch      Branch           @relation(fields: [branchId], references: [id])
  baseSalary  Decimal          @db.Decimal(12, 2)
  hireDate    DateTime         @default(now())
  status      EmployeeStatus   @default(ACTIVE)
  category    EmployeeCategory @default(TEACHING)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  salaryPayments SalaryPayment[]

  @@map("employees")
}

model SalaryPayment {
  id                 String   @id @default(cuid())
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount             Decimal  @db.Decimal(12, 2)
  baseSalary         Decimal  @default(0) @db.Decimal(12, 2)
  allowance1         Decimal  @default(0) @db.Decimal(12, 2)
  allowance2         Decimal  @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal  @default(0) @db.Decimal(12, 2)
  bonus              Decimal  @default(0) @db.Decimal(12, 2)
  loan               Decimal  @default(0) @db.Decimal(12, 2)
  leaveDeduction     Decimal  @default(0) @db.Decimal(12, 2)
  penalty            Decimal  @default(0) @db.Decimal(12, 2)
  subscription       Decimal  @default(0) @db.Decimal(12, 2)
  otherDeduction     Decimal  @default(0) @db.Decimal(12, 2)
  month              Int
  year               Int
  paidDate           DateTime @default(now())
  signedAt           DateTime?
  notes              String?
  createdAt          DateTime @default(now())

  @@map("salary_payments")
}

model Expense {
  id                  String         @id @default(cuid())
  branchId            String
  branch              Branch         @relation(fields: [branchId], references: [id])
  category            String
  description         String?
  amount              Decimal        @db.Decimal(12, 2)
  date                DateTime       @default(now())
  notes               String?
  invoicePath         String?
  invoiceOriginalName String?
  inventoryItemId     String?        @unique
  inventoryItem       InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("expenses")
}

model InventoryCategory {
  id          String                @id @default(cuid())
  name        String
  type        InventoryCategoryType @default(CUSTOM)
  description String?
  branchId    String
  branch      Branch                @relation(fields: [branchId], references: [id])
  createdAt   DateTime              @default(now())

  items InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  categoryId  String
  category    InventoryCategory @relation(fields: [categoryId], references: [id])
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  quantity    Int      @default(0)
  minQuantity Int      @default(0)
  unitPrice   Decimal? @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  distributions InventoryDistribution[]
  expense       Expense?

  @@map("inventory_items")
}

model InventoryDistribution {
  id               String        @id @default(cuid())
  itemId           String
  item             InventoryItem @relation(fields: [itemId], references: [id])
  studentId        String
  student          Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quantity         Int           @default(1)
  distributionDate DateTime      @default(now())
  notes            String?
  distributedById  String
  distributedBy    User          @relation(fields: [distributedById], references: [id])
  createdAt        DateTime      @default(now())

  @@map("inventory_distributions")
}
